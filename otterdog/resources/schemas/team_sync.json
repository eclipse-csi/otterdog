{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "team_sync.json",
  "title": "Team Sync Entry Schema",
  "type": "object",

  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\S.*"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\S.*"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\S.*"
    }
  },

  "required": ["id", "name", "description"],
  "additionalProperties": false
}
